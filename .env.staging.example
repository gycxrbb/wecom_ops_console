# ============================================================
# 旧服务器 gezelling.com 测试/预发布环境
# 用法：复制本文件到服务器 /www/wwwroot/wecom-ops-console/.env 并填写【】
# 角色：测试 CRM（mfgcrmdb）+ 旧机本地 MySQL/Redis/Qdrant；保留作为热备/预发布
# ============================================================

APP_NAME=WeCom Ops Console
APP_ENV=development           # ★ 保持 development，让 CRM_ENV 自动判为 test
HOST=0.0.0.0
PORT=8000
DEFAULT_TIMEZONE=Asia/Shanghai

# ── 密钥（沿用旧机现有值；不要换，否则 webhook 历史密文无法解密） ────
APP_SECRET_KEY=【沿用旧机现有 .env 的值】
JWT_SECRET_KEY=【沿用旧机现有 .env 的值】
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin
ADMIN_PASSWORD=【强密码】
COACH_USERNAME=coach
COACH_PASSWORD=【强密码】

# ── 旧机本地 MySQL / Redis ──────────────────────────────
DATABASE_URL=mysql+pymysql://wecom_ops:【旧机 MySQL 密码】@127.0.0.1:3306/wecom_ops
REDIS_URL=redis://127.0.0.1:6379/0

# ── CRM 双环境（旧机走测试库） ──────────────────────────
CRM_ENV=                       # 留空 = 跟随 APP_ENV (development → test)
CRM_ADMIN_AUTH_ENABLED=true
CRM_PROFILE_ENABLED=true
AI_COACH_ENABLED=true
CRM_ADMIN_TABLE_NAME=admins

# 测试 CRM 库
CRM_TEST_DB_HOST=rm-2zedqey0120581pj9do.mysql.rds.aliyuncs.com
CRM_TEST_DB_PORT=3306
CRM_TEST_DB_USER=mfgcrmuser
CRM_TEST_DB_PASSWORD=【CRM 测试库密码】
CRM_TEST_DB_NAME=mfgcrmdb

# 生产 CRM 库 —— 旧机一般不需要，留空
CRM_PROD_DB_HOST=
CRM_PROD_DB_PORT=3306
CRM_PROD_DB_USER=
CRM_PROD_DB_PASSWORD=
CRM_PROD_DB_NAME=habitilitydb

# 旧机走测试 CRM (mfgcrmdb)，直连无 SSL，故无需 CRM_*_DB_SSL_PATH

CRM_JWT_SECRET_KEY=【沿用旧机现有值】

# ── 七牛云（沿用） ─────────────────────────────────────
ASSET_STORAGE_PROVIDER=qiniu
ASSET_STORAGE_FALLBACK_PROVIDER=local
QINIU_ENABLED=true
QINIU_ACCESS_KEY=【AK】
QINIU_SECRET_KEY=【SK】
QINIU_BUCKET=mengfugui
QINIU_REGION=z0
QINIU_PUBLIC_DOMAIN=cdn.mengfugui.com
QINIU_USE_HTTPS=true
QINIU_PREFIX=qiwei/
QINIU_PRIVATE_BUCKET=false
QINIU_SIGNED_URL_EXPIRE_SECONDS=3600

# ── AI ─────────────────────────────────────────────────
AI_API_KEY=【aihubmix API Key】
AI_BASE_URL=https://aihubmix.com/v1
AI_MODEL=gpt-4o-mini
AI_PROVIDER=aihubmix
AI_HTTP2_ENABLED=true

DEEPSEEK_API_KEY=【DeepSeek API Key】
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

AI_VISUAL_ENABLED=true

# ── 发送 / 上传 ────────────────────────────────────────
SEND_TIMEOUT_SECONDS=30
FILE_UPLOAD_TIMEOUT_SECONDS=120
SEND_MAX_RETRIES=3
SEND_RETRY_DELAY_SECONDS=1.0
FILE_SEND_MAX_RETRIES=3
FILE_SEND_RETRY_DELAY_SECONDS=3.0

# ── RAG（容器化 Qdrant） ───────────────────────────────
RAG_ENABLED=true
QDRANT_MODE=remote
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=wecom_health_rag
RAG_EMBEDDING_BASE_URL=https://aihubmix.com/v1
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSION=1024
RAG_RERANK_ENABLED=false

# ── CORS（公网入口域名走 gezelling.com） ────────────────
CORS_ALLOWED_ORIGINS=https://gezelling.com
