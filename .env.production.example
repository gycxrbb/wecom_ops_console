# ============================================================
# 新服务器 39.106.212.142 生产环境（仅内网访问）
# 用法：复制本文件到服务器 /www/wwwroot/wecom-ops-console/.env 并填写【】
# 角色：生产 CRM (habitilitydb) + 新机本地 MySQL/Redis/Qdrant
# 入口：仅供同内网 CRM 调用 http://<内网IP>:8000；不暴露公网，不配 Nginx/SSL
# ============================================================

APP_NAME=WeCom Ops Console
APP_ENV=production           # ★ 关键：触发 CRM_ENV=production，连 habitilitydb
HOST=0.0.0.0                 # 容器 network_mode: host，8000 端口直接监听宿主机
PORT=8000
DEFAULT_TIMEZONE=Asia/Shanghai

# ── 密钥（生产单独生成，不要复用其他环境的值） ────────────
APP_SECRET_KEY=【openssl rand -base64 32】
JWT_SECRET_KEY=【openssl rand -base64 32】
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin
ADMIN_PASSWORD=【强密码 16 位以上】
COACH_USERNAME=coach
COACH_PASSWORD=【强密码 16 位以上】

# ── 新机本地 MySQL / Redis ──────────────────────────────
DATABASE_URL=mysql+pymysql://wecom_ops:【新机 MySQL 密码】@127.0.0.1:3306/wecom_ops
REDIS_URL=redis://127.0.0.1:6379/0

# ── CRM 双环境（生产连 habitilitydb） ───────────────────
CRM_ENV=                       # 留空 = 跟随 APP_ENV (production → 生产 CRM)
CRM_ADMIN_AUTH_ENABLED=true
CRM_PROFILE_ENABLED=true
AI_COACH_ENABLED=true
CRM_ADMIN_TABLE_NAME=admins

# 测试 CRM 库 —— 生产可不填，避免误连
CRM_TEST_DB_HOST=
CRM_TEST_DB_PORT=3306
CRM_TEST_DB_USER=
CRM_TEST_DB_PASSWORD=
CRM_TEST_DB_NAME=mfgcrmdb

# ★ 生产 CRM 库（habitilitydb）
CRM_PROD_DB_HOST=rm-2zew061b0tlpd75m2.mysql.rds.aliyuncs.com
CRM_PROD_DB_PORT=3306
CRM_PROD_DB_USER=habituser
CRM_PROD_DB_PASSWORD=【habituser 密码】
CRM_PROD_DB_NAME=habitilitydb

CRM_JWT_SECRET_KEY=【生产 CRM 的 APP_PUBLIC_KEY】
CRM_TOKEN_STRICT_REDIS_CHECK=true    # 生产开启 Redis token 严格比对

# ── 七牛云（沿用） ─────────────────────────────────────
ASSET_STORAGE_PROVIDER=qiniu
ASSET_STORAGE_FALLBACK_PROVIDER=local
QINIU_ENABLED=true
QINIU_ACCESS_KEY=【AK】
QINIU_SECRET_KEY=【SK】
QINIU_BUCKET=mengfugui
QINIU_REGION=z0
QINIU_PUBLIC_DOMAIN=cdn.mengfugui.com
QINIU_USE_HTTPS=true
QINIU_PREFIX=qiwei/
QINIU_PRIVATE_BUCKET=false
QINIU_SIGNED_URL_EXPIRE_SECONDS=3600

# ── AI ─────────────────────────────────────────────────
AI_API_KEY=【aihubmix API Key】
AI_BASE_URL=https://aihubmix.com/v1
AI_MODEL=gpt-4o-mini
AI_PROVIDER=aihubmix
AI_HTTP2_ENABLED=true

DEEPSEEK_API_KEY=【DeepSeek API Key】
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

AI_VISUAL_ENABLED=true

# ── 发送 / 上传 ────────────────────────────────────────
SEND_TIMEOUT_SECONDS=30
FILE_UPLOAD_TIMEOUT_SECONDS=120
SEND_MAX_RETRIES=3
SEND_RETRY_DELAY_SECONDS=1.0
FILE_SEND_MAX_RETRIES=3
FILE_SEND_RETRY_DELAY_SECONDS=3.0

# ── RAG（容器化 Qdrant） ───────────────────────────────
RAG_ENABLED=true
QDRANT_MODE=remote
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=wecom_health_rag
RAG_EMBEDDING_BASE_URL=https://aihubmix.com/v1
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSION=1024
RAG_RERANK_ENABLED=false

# ── CORS：放行同内网 CRM 源 ────────────────────────────
# 把 CRM 实际访问的 origin 填进来。CRM 与本服务同机时可填 localhost / 127.0.0.1。
# 多个用逗号分隔。留空 = 仅允许同源（CRM 用 server-to-server 调用时也可以留空）。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://39.106.212.142:8000
