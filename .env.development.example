# ============================================================
# 本地开发环境 (Windows)
# 用法：copy .env.development.example .env   然后填写【】里的占位符
# 角色：本机 Windows 开发，连测试 CRM（mfgcrmdb），不影响任何生产数据
# ============================================================

APP_NAME=WeCom Ops Console
APP_ENV=development
HOST=0.0.0.0
PORT=8000
DEFAULT_TIMEZONE=Asia/Shanghai

# ── 密钥（每个环境单独生成，不要复制粘贴） ─────────────────
APP_SECRET_KEY=【openssl rand -base64 32 生成】
JWT_SECRET_KEY=【openssl rand -base64 32 生成】
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 本地账号（仅在 CRM 登录不可用时兜底） ─────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123456
COACH_USERNAME=coach
COACH_PASSWORD=Coach123456

# ── 项目自有业务库：本机 MySQL ──────────────────────────
DATABASE_URL=mysql+pymysql://root:【你本地 MySQL root 密码】@127.0.0.1:3306/wecom_ops
REDIS_URL=redis://127.0.0.1:6379/0

# ── CRM 双环境（本地默认走 test） ───────────────────────
CRM_ENV=                    # 留空 = 跟随 APP_ENV (development→test)
CRM_ADMIN_AUTH_ENABLED=true
CRM_PROFILE_ENABLED=true
AI_COACH_ENABLED=true
CRM_ADMIN_TABLE_NAME=admins

# 测试 CRM 库（mfgcrmdb）
CRM_TEST_DB_HOST=rm-2zedqey0120581pj9do.mysql.rds.aliyuncs.com
CRM_TEST_DB_PORT=3306
CRM_TEST_DB_USER=mfgcrmuser
CRM_TEST_DB_PASSWORD=【CRM 测试库密码】
CRM_TEST_DB_NAME=mfgcrmdb

# 生产 CRM 库（habitilitydb）—— 本地不需要时留空，避免误连
CRM_PROD_DB_HOST=
CRM_PROD_DB_PORT=3306
CRM_PROD_DB_USER=
CRM_PROD_DB_PASSWORD=
CRM_PROD_DB_NAME=habitilitydb

# CRM JWT 校验（CRM 直连 token 用）
CRM_JWT_SECRET_KEY=【CRM 后端 APP_PUBLIC_KEY】

# ── 七牛云（沿用） ─────────────────────────────────────
ASSET_STORAGE_PROVIDER=qiniu
ASSET_STORAGE_FALLBACK_PROVIDER=local
QINIU_ENABLED=true
QINIU_ACCESS_KEY=【AK】
QINIU_SECRET_KEY=【SK】
QINIU_BUCKET=mengfugui
QINIU_REGION=z0
QINIU_PUBLIC_DOMAIN=cdn.mengfugui.com
QINIU_USE_HTTPS=true
QINIU_PREFIX=qiwei/
QINIU_PRIVATE_BUCKET=false
QINIU_SIGNED_URL_EXPIRE_SECONDS=3600

# ── AI ─────────────────────────────────────────────────
AI_API_KEY=【aihubmix API Key】
AI_BASE_URL=https://aihubmix.com/v1
AI_MODEL=gpt-4o-mini
AI_PROVIDER=aihubmix
AI_HTTP2_ENABLED=true

DEEPSEEK_API_KEY=【DeepSeek API Key】
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── AI Visual ──────────────────────────────────────────
AI_VISUAL_ENABLED=true
# 其余 AI_VISUAL_* 使用 config.py 默认值，已对齐 aihubmix 官方 ≥10 分钟超时建议

# ── 发送 / 上传超时 ────────────────────────────────────
SEND_TIMEOUT_SECONDS=30
FILE_UPLOAD_TIMEOUT_SECONDS=120
SEND_MAX_RETRIES=3
SEND_RETRY_DELAY_SECONDS=1.0
FILE_SEND_MAX_RETRIES=3
FILE_SEND_RETRY_DELAY_SECONDS=3.0

# ── RAG（本地模式：向量存本地文件，无需额外服务） ────────
RAG_ENABLED=true
QDRANT_MODE=local
QDRANT_LOCAL_PATH=data/qdrant
QDRANT_COLLECTION=wecom_health_rag
RAG_EMBEDDING_BASE_URL=https://aihubmix.com/v1
# RAG_EMBEDDING_API_KEY 留空则复用 AI_API_KEY
RAG_RERANK_ENABLED=false

# ── CORS（本地开发用 Vite dev server 时打开） ───────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
