# ===========================
# Python 项目 .gitignore
# ===========================

# --- Python 临时/编译文件 ---
__pycache__/
*.py[cod]
*$py.class
*.so    
*.pyd

# --- 虚拟环境 ---
.venv/
venv/
ENV/
env/
.env/

# --- 打包/分发 ---
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- 测试/覆盖率 ---
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/

# --- 环境变量/配置 ---
.env
.env.*
!.env.example
*.local

# --- 数据库 ---
*.sqlite3
*.sqlite
*.db

# --- 上传/媒体 ---
data/uploads/*
!data/uploads/.gitkeep

# --- 编辑器/IDE ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- 操作系统 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- 日志 ---
logs/
*.log
*.out
*.err
npm-debug.log*

# --- 前端依赖 ---
frontend/node_modules/
frontend/dist/
frontend/.next/

# --- 其他 ---
.github/
*.bak
*.tmp
*.temp
*.tsbuildinfo

.venv/

node_modules/

# 忽略 Qdrant 向量库数据目录
data/qdrant/
*.lock